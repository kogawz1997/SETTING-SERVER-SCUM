{
  "name": "scum-local-control",
  "version": "1.0.6",
  "private": true,
  "description": "Local-first SCUM config control panel for personal use.",
  "author": "KOGA.EXE",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "check": "node scripts/basic-checks.cjs",
    "release:check": "node scripts/release-check.cjs",
    "release:quality": "node scripts/release-quality.cjs",
    "config:roundtrip": "node scripts/config-roundtrip-check.cjs",
    "sample:smoke": "node scripts/sample-workspace-smoke.cjs",
    "performance:smoke": "node scripts/performance-smoke.cjs",
    "docs:check": "node scripts/docs-link-check.cjs",
    "changelog:check": "node scripts/changelog-check.cjs",
    "version:bump": "node scripts/version-bump.cjs",
    "package:portable": "node scripts/create-portable-package.cjs",
    "repair:loot-refs": "node scripts/repair-loot-refs.cjs",
    "test": "npm run check && npm run release:check && npm run test:unit && npm run test:integration && npm run test:ui-smoke && npm run test:loot-regression && npm run test:settings-regression && npm run test:backup-activity",
    "test:unit": "node --test scripts/server-core.unit.test.cjs",
    "test:integration": "node --test scripts/server-api.integration.test.cjs",
    "test:ui-smoke": "node scripts/run-playwright-with-server.cjs scripts/ui-smoke.spec.cjs --reporter=line",
    "test:loot-regression": "node scripts/run-playwright-with-server.cjs scripts/loot-studio-regression.spec.cjs --reporter=line",
    "test:settings-regression": "node scripts/run-playwright-with-server.cjs scripts/settings-command-regression.spec.cjs --reporter=line",
    "test:backup-activity": "node scripts/run-playwright-with-server.cjs scripts/backup-activity-regression.spec.cjs --reporter=line"
  },
  "dependencies": {
    "diff": "^5.2.0",
    "express": "^4.19.2",
    "ini": "^4.1.3"
  }
}
